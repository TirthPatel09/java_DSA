// 2-pointer approach...

class Solution {
    public int maxPower(String s) {
        if(s.length()==1) return 1;
     int i=0;
     int j=0;
     int max_count=0;
     int temp=0;
     while(j<s.length()){
        if(s.charAt(i)==s.charAt(j)){
            temp++;
            j++;
            if(temp>max_count) max_count=temp;
        }
        else{
            temp=0;
            i=j;
        }

     }
     return max_count;

    }
}
