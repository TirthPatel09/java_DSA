class Solution {
    public boolean checkString(String s) {
      int a_last=-1;   // when a never exist
      int b_first=s.length();    // when b never exist in string
      for(int i=0;i<s.length();i++){
        if(s.charAt(i)=='a') a_last=i;
      }
       for(int i=0;i<s.length();i++){
        if(s.charAt(i)=='b') {
        b_first=i;
        break;
      }
       }
      if(a_last>b_first) return false;
      else return true;

        
    }
}
