class Solution {
    public Boolean ispalin(String t){
        int i=0;
        int j=t.length()-1;
        while(i<=j){
            if(t.charAt(i)!=t.charAt(j)) return false;
            i++;
            j--;
        }
        return true;
    }
    public String longestPalindrome(String s) {
        int max_len=-1;
        String ans="";
        for(int i=0;i<s.length();i++){
            for(int j=i;j<s.length();j++){
                String temp=s.substring(i,j+1);
                if(ispalin(temp)){
                    if(max_len<temp.length()){
                        max_len=temp.length();
                        ans=temp;
                    }
                }
            }
        }
        if(ans.equals("")) return s;
        else return ans;
        
    }
}
