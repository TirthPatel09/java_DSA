class Solution {
    public int prefixCount(String[] words, String pref) {
        int pref_len=pref.length();
        int count=0;
        for(String s:words){
            if(s.length()>=pref_len){
            String temp=s.substring(0,pref_len);
            if(temp.equals(pref)){
                count++; 
            } 
            }
        }
        return count;
        
    }
}
