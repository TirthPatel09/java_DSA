class Solution {
    public String trimTrailingVowels(String s) {
        StringBuilder sb=new StringBuilder();
        for(int i=0;i<s.length();i++){
            sb.append(s.charAt(i));
        }
        
        for(int i=s.length()-1;i>=0;i--){
            char ch=s.charAt(i);
            if(ch=='a'|| ch=='e'||ch=='i'||ch=='o'||ch=='u'){
                sb.deleteCharAt(i);
            }
            else break;
        }
        return sb.toString();
    }
}
