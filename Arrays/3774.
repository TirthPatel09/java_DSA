class Solution {
    public int absDifference(int[] nums, int k) {
    int[] freq=new int[101];
    int temp=k;
    int min_sum=0;
    int max_sum=0;

    for(int ele:nums){
        freq[ele]++;
    }
    for(int i=0;i<freq.length;i++){
        if(freq[i]!=0 && k>0){
            int valid=Math.min(k,freq[i]);
            min_sum+=i*valid;
            k-=valid;
        }

    }
    for(int i=freq.length-1;i>=0;i--){
        if(freq[i]!=0 && temp>0){
            int valid=Math.min(temp,freq[i]);
            temp-=valid;
            max_sum+=i*valid;
        }

    }
    return Math.abs(min_sum-max_sum);
        
    }
}
