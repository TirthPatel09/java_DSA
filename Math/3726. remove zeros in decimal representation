class Solution {
    public long removeZeros(long n) {
        long ans=0;
        while(n>0){
            if(n%10!=0){
                ans=(ans*10)+n%10;
            }
            n=n/10;
        }
        long res=0;
        while(ans>0){
          res=(res*10)+ans%10;
          ans=ans/10;
        }
        return res;
        
    }
}
